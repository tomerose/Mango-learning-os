# ─── Supabase ───────────────────────────────────────────────
# Get these from your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only — never expose to the client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── AI Provider (OpenAI-compatible) ────────────────────────
# DeepSeek: https://platform.deepseek.com/  (base URL https://api.deepseek.com)
# Leave AI_API_KEY empty to run the app in mock mode (no live AI calls).
AI_API_KEY=
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat

# ─── Voice (Deepgram) ─────────────────────────────────────────
# Get your free key: https://console.deepgram.com
# Enables production-grade STT/TTS via WebSocket
DEEPGRAM_API_KEY=
